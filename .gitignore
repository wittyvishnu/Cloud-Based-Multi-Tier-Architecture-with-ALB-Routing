# Ignore environment files except .env.example
.env
!.env.example

# Node dependencies and build outputs
node_modules/
.next/
coverage/
build/
dist/
out/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db



# Ignore lock files (optional, comment out if you want to keep them)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Ignore IDE/editor folders
.vscode/
.idea/

# Ignore system files
*.swp
*~

# Ignore production env files
.env.prod

# Ignore all .env in subfolders except .env.example
**/.env
!**/.env.example
